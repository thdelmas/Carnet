<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera + audio for video capture. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Weekly cadence reminder notification (Android 13+). Soft requirement: if denied
         the worker still runs, it just can't surface the prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- CameraCaptureService owns CameraX (Preview + VideoCapture + OverlayEffect) as an
         FGS of type camera|microphone. ScreenCaptureService owns MediaProjection as a
         separate FGS of type mediaProjection. Having the camera client FGS-covered up
         front means MediaProjection's FGS doesn't trigger an OS-level camera re-handshake
         when armed mid-recording (the disconnect that previously killed takes with
         ERROR_SOURCE_INACTIVE). The mediaProjection FGS perm is mandatory from Android 14. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Bios companion-app integration (read vitals at record start, write session events). -->
    <uses-permission android:name="com.bios.app.permission.READ_HEALTH" />
    <uses-permission android:name="com.bios.app.permission.WRITE_COMPANION" />

    <!-- Required to query the Bios providers on Android 11+. -->
    <queries>
        <package android:name="com.bios.app" />
        <provider android:authorities="com.bios.app.health" />
        <provider android:authorities="com.bios.app.companion" />
    </queries>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Carnet"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:label="@string/history_title"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SeriesActivity"
            android:exported="false"
            android:label="@string/series_title"
            android:parentActivityName=".SettingsActivity"
            android:screenOrientation="portrait" />

        <service
            android:name=".CameraCaptureService"
            android:exported="false"
            android:foregroundServiceType="camera|microphone" />

        <service
            android:name=".ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>

</manifest>
