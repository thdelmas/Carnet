<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="@color/carnet_text" />
            <size
                android:width="68dp"
                android:height="68dp" />
        </shape>
    </item>
    <item
        android:left="22dp"
        android:top="22dp"
        android:right="22dp"
        android:bottom="22dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/carnet_rec" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</layer-list>
